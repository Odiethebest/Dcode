# ============================================================
# Dcode production environment variables.
# Copy to `.env.production` on the deployment host and review
# every placeholder before `docker compose -f docker-compose.yml
# -f docker-compose.prod.yml up -d --build`.
# ============================================================

# --- Public entrypoint ---
PUBLIC_HTTP_PORT=80
PUBLIC_ORIGIN=http://dcode.odieyang.com

# --- PostgreSQL ---
POSTGRES_USER=dcode
POSTGRES_PASSWORD=__SET_PROD_POSTGRES_PASSWORD__
POSTGRES_DB=dcode
DATABASE_URL=postgresql+asyncpg://dcode:__SET_PROD_POSTGRES_PASSWORD__@postgres:5432/dcode

# --- Internal services ---
REDIS_URL=redis://redis:6379/0
RABBITMQ_USER=__SET_PROD_RABBITMQ_USER__
RABBITMQ_PASSWORD=__SET_PROD_RABBITMQ_PASSWORD__
RABBITMQ_URL=amqp://__SET_PROD_RABBITMQ_USER__:__SET_PROD_RABBITMQ_PASSWORD__@rabbitmq:5672/
AGENT_URL=http://agent:8001

# --- Internal service auth ---
INTERNAL_API_KEY=__SET_PROD_INTERNAL_API_KEY__

# --- Model / runtime knobs ---
LOG_LEVEL=info
EMBEDDING_MODEL=stub
EMBEDDING_DIM=1024
RERANKER_ENDPOINT=http://localhost:9999
JUDGE_MODEL=stub
