# ============================================================
# Dcode environment variables.
# Copy to .env and fill in. Never commit .env.
#
# These values are the host-side defaults (used when you run
# `uv run` or `npm run dev` directly on the host).
# `docker compose up` overrides hostnames in docker-compose.yml
# to internal docker network names (postgres, redis, rabbitmq).
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=dcode
POSTGRES_PASSWORD=__SET_LOCAL_DEV_POSTGRES_PASSWORD__
POSTGRES_DB=dcode

# --- Service URLs (host-side defaults) ---
DATABASE_URL=postgresql+asyncpg://dcode:__SET_LOCAL_DEV_POSTGRES_PASSWORD__@localhost:5432/dcode
REDIS_URL=redis://localhost:6379/0
RABBITMQ_USER=dcode
RABBITMQ_PASSWORD=__SET_LOCAL_DEV_RABBITMQ_PASSWORD__
RABBITMQ_URL=amqp://dcode:__SET_LOCAL_DEV_RABBITMQ_PASSWORD__@localhost:5672/
AGENT_URL=http://localhost:8001

# --- CORS for the frontend (comma-separated list) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Logging ---
LOG_LEVEL=info

# --- Internal service auth ---
INTERNAL_API_KEY=__SET_LOCAL_DEV_INTERNAL_API_KEY__

# ============================================================
# Open Decisions placeholders (see docs/PLAN.md §9).
# OD-1 (target repo) and OD-5 (domain) are not env vars.
# ============================================================

# OD-2: Embedding model. Use 'stub' until the real client is wired (M2).
EMBEDDING_MODEL=stub
EMBEDDING_DIM=1024
# When EMBEDDING_MODEL is not stub, point worker + API at the embedding sidecar:
# EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
# EMBEDDING_DIM=768
# EMBEDDING_ENDPOINT=http://host.docker.internal:8002
# EMBEDDING_BATCH_SIZE=1
# On MacBook: run `make embedding-host` in a separate terminal (recommended).
# Or Docker sidecar: docker compose --profile embedding up -d embedding

# OD-3: Reranker endpoint (cross-encoder). Placeholder until M2.
RERANKER_ENDPOINT=http://localhost:9999

# OD-4: Judge model for the evaluation harness. Placeholder until M3.
JUDGE_MODEL=stub
